# ==========================================
# Icarus Del Duca LLC - Heliopause Standard
# Python & Terraform Unified Gitignore
# ==========================================

### Terraform Specifics ###
# Local .terraform directories
**/.terraform/*

# .tfstate files (CRITICAL: These contain secrets and must NEVER be committed)
*.tfstate
*.tfstate.*
crash.log
*.tfvars
*.tfvars.json

# Variables and overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration files
.terraformrc
terraform.rc

### Python Specifics ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments (Standardized)
.venv/
venv/
ENV/
env/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.pyo
.hypothesis/
.pytest_cache/
cover/

### General OS/IDE Artifacts ###
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

### Heliopause Specifics ###
# Ignore local testing logs or dry-run outputs
heliopause_debug.log
.solstice_cache/
response.json
*.zip
